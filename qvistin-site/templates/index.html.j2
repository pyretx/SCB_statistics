<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{ site.title }}</title>
<meta name="description" content="{{ site.description }}">
<meta property="og:title" content="{{ site.title }}">
<meta property="og:description" content="{{ site.description }}">
<meta property="og:type" content="website">
<link rel="icon" href="data:image/svg+xml,{{ favicon_svg }}">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="static/css/site.css?v={{ asset_v }}">
<style>:root { --accent: {{ site.accent }}; }</style>
</head>
<body>
<div class="page">

  {# ── icon macro ─────────────────────────────────────────────────────────── #}
  {% macro icon(name) -%}
  {%- if name == 'logo' -%}
    <svg class="ico-logo" viewBox="0 0 32 32" fill="none" aria-hidden="true"><circle cx="14" cy="13" r="8" stroke="#12151A" stroke-width="2.4"/><path d="M19.5 19.5 L24 24" stroke="#12151A" stroke-width="2.4" stroke-linecap="round"/><path d="M24 24 L28 21" stroke="var(--accent)" stroke-width="2.4" stroke-linecap="round"/><path d="M24 24 L26 29" stroke="var(--accent)" stroke-width="2.4" stroke-linecap="round"/><circle cx="29.2" cy="20" r="1.9" fill="var(--accent)"/><circle cx="26.8" cy="30.2" r="1.9" fill="var(--accent)"/></svg>
  {%- elif name == 'globe' -%}
    <svg viewBox="0 0 24 24" fill="none" stroke="#FAFAF9" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M3 12h18"/><ellipse cx="12" cy="12" rx="4" ry="9"/></svg>
  {%- elif name == 'chart' -%}
    <svg viewBox="0 0 24 24" fill="none" stroke="#6A727A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 17 L8.5 10.5 L13 13.5 L20 5"/><path d="M20 5 h-4.5 M20 5 v4.5"/><circle cx="3" cy="17" r="1.6" fill="#6A727A" stroke="none"/></svg>
  {%- elif name == 'blocks' -%}
    <svg viewBox="0 0 24 24" fill="none" stroke="#6A727A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="4" width="7" height="7" rx="1.5"/><rect x="13.5" y="13.5" width="7" height="7" rx="1.5"/><path d="M7.5 11v4a2 2 0 0 0 2 2h4"/></svg>
  {%- elif name == 'plus' -%}
    <svg viewBox="0 0 24 24" fill="none" stroke="#B0B6BB" stroke-width="2" stroke-linecap="round"><path d="M12 5v14M5 12h14"/></svg>
  {%- elif name == 'arrow' -%}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
  {%- elif name == 'mail' -%}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="5" width="20" height="14" rx="2"/><path d="m2 7 10 6 10-6"/></svg>
  {%- elif name == 'linkedin' -%}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-4 0v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
  {%- elif name == 'github' -%}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
  {%- elif name == 'check' -%}
    <svg viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
  {%- endif -%}
  {%- endmacro %}

  <!-- NAV -->
  <header class="nav">
    <a class="brand" href="#top">{{ icon('logo') }}<span>{{ site.brand }}</span></a>
    <nav class="nav-links">
      {% for l in nav %}<a href="{{ l.href }}">{{ l.label }}</a>{% endfor %}
    </nav>
  </header>

  <!-- HERO -->
  <section id="top" class="hero">
    <div class="fade-up">
      <svg class="hero-mark" viewBox="0 0 32 32" fill="none" aria-hidden="true"><circle cx="14" cy="13" r="8" stroke="#12151A" stroke-width="2"/><path d="M19.5 19.5 L24 24" stroke="#12151A" stroke-width="2" stroke-linecap="round"/><path d="M24 24 L28 21" stroke="var(--accent)" stroke-width="2" stroke-linecap="round"/><path d="M24 24 L26 29" stroke="var(--accent)" stroke-width="2" stroke-linecap="round"/><circle cx="29.2" cy="20" r="1.7" fill="var(--accent)"/><circle cx="26.8" cy="30.2" r="1.7" fill="var(--accent)"/></svg>
      <h1>{{ hero.heading }}</h1>
      <p class="lead">{{ hero.subheading }}</p>
      <p class="tagline">{{ hero.tagline }}</p>
      <div class="hero-cta">
        <a class="btn btn-dark" href="{{ hero.cta_primary_href }}">{{ hero.cta_primary_label }}</a>
        <a class="btn btn-ghost" href="{{ hero.cta_secondary_href }}">{{ hero.cta_secondary_label }}</a>
      </div>
    </div>
  </section>

  <!-- BRANCHING ILLUSTRATION -->
  <section class="diagram">
    <div class="diagram-wrap">
      <svg class="branch-svg" viewBox="0 0 1000 430" aria-hidden="true">
        <g class="foundation">
          <circle cx="500" cy="392" r="26" fill="#12151A"/>
          <circle cx="500" cy="392" r="26" fill="none" stroke="#12151A" stroke-opacity="0.12" stroke-width="12"/>
          <g transform="translate(500,392)"><circle cx="-1.5" cy="-2" r="6.5" stroke="#FAFAF9" stroke-width="2" fill="none"/><path d="M3 3 L7 7" stroke="#FAFAF9" stroke-width="2" stroke-linecap="round"/></g>
        </g>
        {% for b in branches %}
        <g class="branch{% if b.live %} is-live{% endif %}{% if b.href %} branch-link{% endif %}" data-i="{{ loop.index0 }}"{% if b.href %} data-href="{{ b.href }}"{% endif %}>
          <path class="branch-base" d="{{ b.path }}" fill="none" stroke="#D8DBDD" stroke-width="2" stroke-dasharray="600" style="animation:growPath 1.4s cubic-bezier(.22,1,.36,1) {{ b.path_delay }}s both"/>
          <path class="branch-glow" d="{{ b.path }}" fill="none" stroke="var(--accent)" stroke-width="2.5" stroke-dasharray="600" style="stroke-dashoffset:0"/>
          <circle cx="{{ b.x }}" cy="{{ b.y }}" r="30" fill="transparent"/>
          <circle class="branch-node" cx="{{ b.x }}" cy="{{ b.y }}" r="{{ b.r }}" fill="{{ b.fill }}" stroke="{{ b.stroke }}" stroke-width="2" style="animation:nodeIn .5s ease {{ b.node_delay }}s both;transform-origin:{{ b.x }}px {{ b.y }}px"/>
          {% if b.live %}<circle cx="{{ b.x }}" cy="{{ b.y }}" r="4.5" fill="#FAFAF9"/>{% endif %}
        </g>
        {% endfor %}
      </svg>
      {% for b in branches %}
      <div class="branch-label{% if b.live %} is-live{% endif %}" data-i="{{ loop.index0 }}" style="left:{{ b.label_left }}%;top:{{ b.label_top }}%">{{ b.label }}</div>
      {% endfor %}
      <div class="diagram-caption">{{ diagram.caption }}</div>
    </div>
  </section>

  <!-- PRODUCTS -->
  <section id="products" class="products">
    <div class="eyebrow eyebrow-accent">{{ products.eyebrow }}</div>
    <h2>{{ products.heading }}</h2>
    <div class="product-grid">
      {% for p in products['item'] %}
      <div class="card{% if p.status == 'soon' %} card-soon{% endif %}">
        <div class="card-top">
          <div class="card-icon icon-{{ p.status }}">{{ icon(p.icon) }}</div>
          {% if p.status == 'live' %}<span class="badge badge-live"><span class="dot"></span>LIVE</span>
          {% elif p.status == 'dev' %}<span class="badge badge-dev">IN&nbsp;DEVELOPMENT</span>{% endif %}
        </div>
        <div class="card-name{% if p.status == 'soon' %} muted{% endif %}">{{ p.name }}</div>
        <p class="card-desc{% if p.status == 'soon' %} muted{% endif %}">{{ p.desc }}</p>
        {% if p.cta_label %}<a class="card-launch" href="{{ p.cta_href }}">{{ p.cta_label }} {{ icon('arrow') }}</a>{% endif %}
      </div>
      {% endfor %}
    </div>
  </section>

  <!-- ABOUT -->
  <section id="about" class="about">
    <div class="about-inner">
      <div class="eyebrow eyebrow-teal">{{ about.eyebrow }}</div>
      <p class="about-statement">{{ about.statement }}</p>
      <div class="about-values">
        {% for v in about['values'] %}<span>{{ v }}</span>{% if not loop.last %}<span class="value-dot"></span>{% endif %}{% endfor %}
      </div>
      <a class="btn btn-outline-dark" href="{{ about.cta_href }}">{{ about.cta_label }}</a>
    </div>
  </section>

  <!-- CONTACT -->
  <section id="contact" class="contact">
    <div class="contact-grid">
      <div>
        <div class="eyebrow eyebrow-accent">{{ contact.eyebrow }}</div>
        <h2>{{ contact.heading }}</h2>
        <p class="contact-blurb">{{ contact.blurb }}</p>
        <div class="contact-links">
          <a class="contact-link" href="mailto:{{ contact.email }}">{{ icon('mail') }}{{ contact.email }}</a>
          {% for l in contact.get('link', []) %}<a class="contact-link" href="{{ l.href }}">{{ icon(l.icon) }}{{ l.label }}</a>{% endfor %}
        </div>
      </div>

      <form class="contact-card" id="contact-form"
            data-supabase-url="{{ (contact.get('backend') or {}).get('supabase_url', '') }}"
            data-supabase-key="{{ (contact.get('backend') or {}).get('supabase_anon_key', '') }}">
        <div class="form-fields">
          <div class="form-row">
            <div><div class="field-label">NAME</div><input id="f-name" maxlength="200" placeholder="Your name" autocomplete="name"></div>
            <div><div class="field-label">EMAIL</div><input id="f-email" type="email" maxlength="320" placeholder="name@company.com" autocomplete="email"></div>
          </div>
          <div>
            <div class="field-label">TOPIC</div>
            <div class="topics" id="topics">
              {% for t in contact.topics %}<button type="button" class="topic{% if loop.first %} is-active{% endif %}" data-topic="{{ t }}">{{ t }}</button>{% endfor %}
            </div>
          </div>
          <div>
            <div class="field-label">MESSAGE</div>
            <textarea id="f-msg" rows="4" maxlength="5000" placeholder="What's on your mind?"></textarea>
          </div>
          <div class="form-foot">
            <span class="form-note">{{ contact.form_note }}</span>
            <button type="submit" class="btn-send" id="f-send" data-email="{{ contact.email }}">Send message {{ icon('arrow') }}</button>
          </div>
          <div class="form-err" id="form-err" hidden>Couldn't send just now — please email <a href="mailto:{{ contact.email }}">{{ contact.email }}</a>.</div>
        </div>
        <div class="form-sent" id="form-sent" hidden>
          <div class="sent-check">{{ icon('check') }}</div>
          <div class="sent-title">Message sent.</div>
          <p class="sent-note">Thanks — we'll get back to you shortly.</p>
          <button type="button" class="sent-again" id="f-again">Write another</button>
        </div>
      </form>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="footer-inner">
      <span class="mono footer-powered">{{ footer.powered }}</span>
      <span class="footer-loc">{{ footer.location }}</span>
      <span class="mono footer-copy">{{ footer.copyright }}</span>
    </div>
  </footer>

</div>
<script src="static/js/site.js?v={{ asset_v }}" defer></script>
</body>
</html>
